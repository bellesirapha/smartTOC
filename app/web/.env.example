# LLM provider: openai | azure | github
# GitHub Models (free tier) — generate a token at https://github.com/settings/tokens
VITE_LLM_PROVIDER=github
VITE_LLM_API_KEY=your_github_personal_access_token_here
VITE_LLM_MODEL=gpt-4o-mini

# Azure OpenAI — only needed when VITE_LLM_PROVIDER=azure
# VITE_LLM_AZURE_ENDPOINT=https://<resource>.openai.azure.com/openai/deployments/<deploy>/chat/completions?api-version=2024-08-01-preview
